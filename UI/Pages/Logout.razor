@page "/logout"
@inject AuthService AuthService // Injects AuthService so we can call LogoutAsync
@inject NavigationManager Nav // Injects NavigationManager to navigate to the login page after logout
@using JwtAuthDemoUI.Services // Brings in the namespace for AuthService

<h3>Logout</h3>

<p>Log out of this account? Click the button below to log out.</p>
<!-- Button triggers HandleLogout method -->
<button class="btn btn-danger" @onclick="HandleLogout">Logout</button>

@code {
    private async Task HandleLogout() // Handles the logout process
    {
        await AuthService.LogoutAsync(); // Calls AuthService.LogoutAsync to clear the JWT token and log the user out.
        Nav.NavigateTo("/login", forceLoad: true); // After logging out, navigate to the login page. forceLoad: true forces a full page reload to clear any cached state.
    }
}
